# QuantBot AI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# ─── APLICAÇÃO ───────────────────────────────────────────────────────────────
APP_NAME=QuantBot AI
APP_ENV=production          # development | production
APP_PORT=8000
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_DE_64_CHARS_MINIMO
ENCRYPTION_KEY=CHAVE_AES256_PARA_CREDENCIAIS_BINANCE_32BYTES

# ─── BANCO DE DADOS ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://quantbot:senha_forte@db:5432/quantbot_db
POSTGRES_USER=quantbot
POSTGRES_PASSWORD=senha_forte
POSTGRES_DB=quantbot_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=OUTRO_SECRET_PARA_JWT_DIFERENTE_DO_APP_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440     # 24 horas

# ─── IA ──────────────────────────────────────────────────────────────────────
AI_PROVIDER=openai          # openai | gemini | rules
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...

# ─── BINANCE ─────────────────────────────────────────────────────────────────
BINANCE_TESTNET=false       # true para usar testnet (recomendado em dev)

# ─── TELEGRAM ────────────────────────────────────────────────────────────────
# As credenciais Telegram são salvas por usuário no banco.
# Configure aqui apenas para notificações de sistema (admin).
ADMIN_TELEGRAM_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# ─── REDIS (opcional — para cache e rate limit) ───────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://seudominio.com
